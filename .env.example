# .env.example
# Copy this file to .env and fill in your values.
# .env is git-ignored and loaded automatically by `npx quartz` at startup.
#
# These variables are available anywhere in quartz.config.ts / quartz.plugins.ts
# via process.env.VARIABLE_NAME — useful for keeping secrets out of version control.
#
# Examples:
# PLAUSIBLE_HOST=https://analytics.example.com
# GISCUS_REPO_ID=your_repo_id
# BASE_URL=machugram.github.io
